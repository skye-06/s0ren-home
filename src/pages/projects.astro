---
import MainGridLayout from "@layouts/MainGridLayout.astro";
import siteContent from "../data/site-content.json";
---

<MainGridLayout title="项目" description="S0ren 的学习项目">
	<section class="card-base px-6 py-7 md:px-9">
		<header class="mb-6">
			<h1 class="text-3xl font-bold text-90">项目</h1>
			<p class="font-reading mt-2 text-75">记录测绘、导航与空间智能方向的学习实践。</p>
		</header>

		<div class="grid gap-4">
			{
				siteContent.projects.map((project) => (
					<article class="rounded-2xl border border-black/10 p-5 dark:border-white/10">
						{project.badge && (
							<p class="text-sm font-medium text-[var(--primary)]">{project.badge}</p>
						)}
						<h2 class="mt-2 text-xl font-bold text-90">{project.title}</h2>
						<p class="font-reading mt-2 text-75">{project.description}</p>
						<div class="mt-5 flex flex-wrap gap-3">
							{project.primaryLabel && project.primaryUrl && (
								<a class="btn-regular px-4 py-2 font-medium" href={project.primaryUrl}>
									{project.primaryLabel}
								</a>
							)}
							{project.secondaryLabel && project.secondaryUrl && (
								<a class="btn-plain px-4 py-2 font-medium" href={project.secondaryUrl}>
									{project.secondaryLabel}
								</a>
							)}
						</div>
					</article>
				))
			}
		</div>
	</section>
</MainGridLayout>
